# AIM environment example.
# Copy to .env and fill in local values. Never commit .env.

# App
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
WEB_CONCURRENCY=1

# Auth
# Empty list means open dev mode. Use real keys before exposing AIM publicly.
API_KEYS=[]
RATE_LIMIT_PER_MINUTE=60
CORS_ORIGINS=http://localhost:3000

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# Vector DB
# qdrant is the local-first default. pinecone is optional.
VECTOR_DB_PROVIDER=qdrant
VECTOR_DB_URL=http://localhost:6333
PINECONE_API_KEY=
PINECONE_INDEX_NAME=aim-knowledge
PINECONE_ENVIRONMENT=us-east-1
PINECONE_NAMESPACE=default
EMBEDDING_DIMENSION=1536

# LLM
# local means Ollama/vLLM/LM Studio style OpenAI-compatible server.
LLM_PROVIDER=local
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b-instruct-q4_K_M
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=768
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_CACHE_SIZE=2000

# Slack live ingest
WEBHOOK_SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_DEFAULT_CHANNELS=general,engineering

# Jira / Confluence
WEBHOOK_JIRA_SECRET=
WEBHOOK_CONFLUENCE_SECRET=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_DEFAULT_PROJECTS=ENG

# Redis is optional in development. AIM falls back to in-memory cache/thread state.
REDIS_URL=redis://localhost:6379

# Conversation and feedback retention
CONVERSATION_MAX_TURNS=10
CONVERSATION_TTL_SECONDS=604800
FEEDBACK_TTL_SECONDS=7776000

# Retrieval tuning
MAX_SUB_QUERIES=5
TOP_K_VECTORS=10
GRAPH_SEARCH_DEPTH=2
GRAPH_HUB_DEGREE_LIMIT=25
GRAPH_USE_HYBRID_SEARCH=true
GRAPH_PROACTIVE_PATHS=true
GRAPH_TEACHER_BFS_ENABLED=true
GRAPH_TEACHER_BFS_LIMIT=20
SIMILARITY_THRESHOLD=0.75

# Timeouts
ROUTE_TIMEOUT_SECONDS=60
NODE_TIMEOUT_SECONDS=20
NEO4J_QUERY_TIMEOUT_SECONDS=10
MCP_PROVIDER_TIMEOUT_SECONDS=15
MCP_HANDLER_TIMEOUT_SECONDS=25

# Optional security/observability
MULTI_TENANT=false
ENCRYPTION_KEY=
ENCRYPTED_FIELDS=
OTLP_ENDPOINT=
